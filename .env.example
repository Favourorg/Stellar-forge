# Server-side environment for the IPFS upload proxy (api/ipfs/*).
#
# These are read by the serverless functions at request time and are never
# bundled into the client. Do NOT add a VITE_ prefix to them - that would
# inline them into the browser bundle and publish them to every visitor.
#
# Get your API key and secret from https://app.pinata.cloud/keys
# The key needs the pinFileToIPFS and pinJSONToIPFS permissions.
PINATA_API_KEY=your_pinata_api_key_here
PINATA_API_SECRET=your_pinata_api_secret_here
